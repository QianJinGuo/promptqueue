{
  "name": "@promptqueue/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    }
  },
  "scripts": {
    "build": "tsc && rm -rf dist/storage/migrations && cp -r src/storage/migrations dist/storage/migrations",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@promptqueue/core": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.7.0",
    "better-sqlite3": "^12.6.0",
    "hono": "^4.7.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "openai": "^4.100.0",
    "ulid": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0"
  }
}
